# Option 1: Explicit token (for CI or manual use)
# GH_CONTRIBUTE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: GitHub App credentials (generates installation token automatically)
# GH_CONTRIBUTE_APP_ID=123456
# GH_CONTRIBUTE_PRIVATE_KEY=<base64-encoded PEM private key>
# GH_CONTRIBUTE_PRIVATE_KEY_PATH=/path/to/private-key.pem
# GH_CONTRIBUTE_INSTALLATION_ID=12345678  # optional, auto-detected if not set
